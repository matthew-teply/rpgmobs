<?xml version="1.0" encoding="UTF-8" ?>
<ldlib2-ui xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/Low-Drag-MC/LDLib2/refs/heads/1.21/ldlib2-ui.xsd">

    <stylesheet location="ldlib2:lss/mc.lss"/>
    <style>
        .__progress-bar_bar__ {
        background: #FF4852FF;
        }

        .__scroller_view_view-port__ {
        background: empty;
        }

        .__progress-bar_label__ {
        font-size: 7;
        }

        button > text:internal {
        font-size: 7;
        }

        .root {
        display: flex;
        width: 100%;
        height: 100%;
        padding-all: 10;
        align-items: center;
        justify-content: end;
        }

        .height-adaptive {
        adaptive-height: true;
        }

        .width-adaptive {
        adaptive-width: true;
        }

        .width-full {
        width: 100%;
        }

        .wrap {
        text-wrap: WRAP;
        }

        .font-standard {
        font-size: 7;
        }

        .font-small {
        font-size: 6;
        }

        .label {
        color: #FFFFFFFF;
        text-shadow: false;
        }

        .container {
        display: flex;
        width: 70%;
        height: 50%;
        min-height: 200;
        background: built-in(ui-mc:BORDER);
        }

        .title-container {
        display: flex;
        flex-direction: row;
        width: 100%;
        background: built-in(ui-mc:RECT_THIN);
        }

        .title {
        adaptive-width: true;
        background: built-in(ui-mc:BORDER);
        vertical-align: center;
        horizontal-align: center;
        padding-all: 10;
        padding-left: 15;
        padding-right: 15;
        }

        .body-container {
        flex: 1;
        display: flex;
        flex-direction: row;
        padding-all: 10;
        padding-top: 5;
        gap-all: 5;
        }

        .content-scroller {
        scroller-view-mode: VERTICAL;

        position: relative;
        flex: 3;
        background: built-in(ui-mc:BORDER);
        height: 100%;
        padding-all: 10;
        }

        .content {
        width: 100%;
        text-wrap: WRAP;
        }

        .dialogue-entry {
        adaptive-height: true;
        margin-bottom: 10;
        }

        .dialogue-inline-button {
        base-background: empty;
        hover-background: empty;
        pressed-background: empty;
        adaptive-width: true;
        adaptive-height: true;
        height: auto;
        padding-all: 0;
        }

        .dialogue-inline-button > text:internal {
        font-size: 7;
        color: #FF44AAFF;
        adaptive-height: true;
        margin-horizontal: 0;
        }

        .dialogue-inline-button:hover > text:internal {
        color: #FFFFFF;
        }

        .line-break {
        width: 100%;
        height: 7;
        }

        .dialogue-entry-question {
        adaptive-height: true;
        text-wrap: WRAP;
        margin-bottom: 4;
        color: #88FFFFFF;
        }

        .dialogue-entry-answer {
        width: 100%;
        flex-wrap: wrap;
        flex-direction: ROW;
        justify-content: start;
        align-items: center;
        adaptive-height: true;
        text-wrap: WRAP;
        }

        .dialogue-entry-answer label {
        color: #FFFFFF33;
        }

        .actions-container {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap-all: 5;
        }

        .topics-container {
        scroller-view-mode: VERTICAL;

        flex: 1;
        display: flex;
        background: built-in(ui-mc:BORDER);
        padding-all: 2;
        padding-top: 4;
        padding-bottom: 4;
        }

        .topics-container button {
        base-background: empty;
        hover-background: #55000000;
        pressed-background: empty;
        align-items: center;
        justify-content: start;
        padding-all: 4;
        padding-top: 4;
        padding-bottom: 2;
        height: auto;
        }

        .topics-container button > text:internal {
        font-size: 7;
        color: #FF44AAFF;
        adaptive-height: true;
        }
    </style>

    <root class="root">
        <element class="container">
            <element class="title-container">
                <element style="flex: 1;">
                </element>
                <label id="title" class="title font-standard">
                </label>
                <element style="flex: 1;">
                </element>
            </element>

            <element class="body-container">
                <scroller-view id="content-scroller" class="content-scroller">
                    <element id="content">
                    </element>
                    <element id="content-test">
                    </element>
                </scroller-view>

                <element class="actions-container">

                    <element>
                        <label class="label font-small">Reputation</label>
                        <progress-bar id="relationship-bar" min-value="0" max-value="100" value="65" text="65/100"/>
                    </element>

                    <element style="flex: 1;">
                        <label class="label font-small">Topics</label>
                        <scroller-view id="topics" class="topics-container">
                        </scroller-view>
                    </element>

                    <button id="button-exit" text="Goodbye"/>
                </element>
            </element>
        </element>
    </root>
</ldlib2-ui>