.__progress-bar_bar__ {
    background: #FF4852FF;
}

.__scroller_view_view-port__ {
    background: empty;
}

.__progress-bar_label__ {
    font-size: 8;
}

button > text:internal {
    font-size: 8;
}

.root {
    display: flex;
    width: 800;
    height: 600;
    padding-all: 10;
    align-items: center;
    justify-content: center;
}

.font-standard {
    font-size: 8;
}

.font-small {
    font-size: 6;
}

.label {
    color: #FF444444;
    text-shadow: false;
}

.container {
    display: flex;
    width: 85%;
    height: 50%;
    background: built-in(ui-mc:RECT_THIN);
}

.title-container {
    display: flex;
    flex-direction: row;
    width: 100%;
    background: built-in(ui-mc:RECT_THIN);
}

.title {
    adaptive-width: true;
    background: built-in(ui-mc:BORDER);
    vertical-align: center;
    horizontal-align: center;
    padding-all: 10;
    padding-left: 15;
    padding-right: 15;
}

.body-container {
    flex: 1;
    display: flex;
    flex-direction: row;
    padding-all: 10;
    padding-top: 5;
    gap-all: 5;
}

.content-container {
    scroller-view-mode: VERTICAL;

    flex: 3;
    background: built-in(ui-mc:BORDER);
    height: 100%;
    padding-all: 10;
}

.actions-container {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap-all: 8;
}

.topics-container {
    scroller-view-mode: VERTICAL;

    flex: 1;
    display: flex;
    background: built-in(ui-mc:BORDER);
    padding-all: 2;
    padding-top: 4;
    padding-bottom: 4;
}

.topic {
    base-background: empty;
    hover-background: #55000000;
    pressed-background: empty;
    align-items: center;
    justify-content: start;
    padding-all: 4;
    padding-top: 4;
    padding-bottom: 2;
    height: auto;
}

.topic > text:internal {
    font-size: 8;
    color: #FF44AAFF;
    adaptive-height: true;
}